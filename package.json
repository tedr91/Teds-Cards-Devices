{
  "name": "teds-device-cards",
  "version": "0.0.2",
  "description": "A collection of custom Lovelace cards for specific devices, for Home Assistant.",
  "private": false,
  "type": "module",
  "main": "dist/teds-device-cards.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "screenshots": "npm run build && node scripts/gen-screenshots.mjs",
    "screenshots:install": "playwright install chromium"
  },
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hacs",
    "lovelace",
    "custom-cards",
    "teds-device-cards"
  ],
  "author": "tedr91",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tedr91/Teds-Cards-Devices.git"
  },
  "bugs": {
    "url": "https://github.com/tedr91/Teds-Cards-Devices/issues"
  },
  "homepage": "https://github.com/tedr91/Teds-Cards-Devices#readme",
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "playwright": "^1.49.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}
